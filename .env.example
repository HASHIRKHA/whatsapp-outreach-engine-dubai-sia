# ─────────────────────────────────────────────────────────────────────────────
# WA Outreach Engine — Environment Variables
# Copy this file to .env and fill in all REQUIRED values before starting.
# Never commit the real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────

# REQUIRED  Node environment (production | development | test)
NODE_ENV=production

# OPTIONAL  Shared secret for the API key guard (X-API-Key header).
#           When set, ALL non-public API endpoints require this header.
#           Public endpoints (webhooks, /health) are always exempt.
#           Generate with: openssl rand -hex 32
#           Leave empty to disable the guard (not recommended in production).
API_KEY=

# REQUIRED  Set to true until you have verified real sends work correctly.
#           When true, messages are logged instead of sent (safe for testing).
DRY_RUN=true

# REQUIRED  Domain name for production SSL and CORS.
DOMAIN=yourdomain.com

# ── Database — Supabase ───────────────────────────────────────────────────────

# REQUIRED  Pooler URL (port 6543) — used by Prisma Client at runtime.
#           Get from Supabase → Settings → Database → Connection string (Transaction mode).
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# REQUIRED  Direct URL (port 5432) — used by Prisma Migrate only.
#           Get from Supabase → Settings → Database → Connection string (Direct).
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres

# ── Cache / Queue ─────────────────────────────────────────────────────────────

# REQUIRED (docker-compose)  Redis password. docker-compose sets REDIS_URL automatically using this.
#           For external Redis (e.g. Redis Cloud), ignore this and set REDIS_URL directly below.
#           Generate with: openssl rand -hex 16
REDIS_PASSWORD=

# REQUIRED  Redis connection URL.
#           docker-compose overrides this automatically from REDIS_PASSWORD.
#           For external Redis, set this directly: redis://:password@host:port/db
REDIS_URL=redis://redis:6379

# ── Meta Cloud API — Mode 1 (official WhatsApp Business API) ─────────────────

# REQUIRED for Cloud API.  Used to validate X-Hub-Signature-256 on incoming webhooks.
#           Find in Meta Developer Console → App → Settings → Basic → App Secret.
#           Without this, the webhook endpoint accepts unsigned payloads (security risk).
META_APP_SECRET=
META_VERIFY_TOKEN=
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_WABA_ID=

# OPTIONAL  BCP-47 language code used for all Cloud API template sends (default: en_US).
#           Override if your Meta-approved templates are in a different language, e.g. ur (Urdu),
#           ar (Arabic), es_AR (Spanish Argentina). Find the exact code in Meta Business Manager.
META_DEFAULT_TEMPLATE_LANGUAGE=en_US

# ── AI — NEXUS Campaign Brain ─────────────────────────────────────────────────

# REQUIRED  AI provider to use for message generation and reply analysis.
#           Values: anthropic (default) | openai
AI_PROVIDER=anthropic

# REQUIRED when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# REQUIRED when AI_PROVIDER=openai
OPENAI_API_KEY=

# ── Anti-ban ─────────────────────────────────────────────────────────────────

# REQUIRED  32-byte key for encrypting Baileys session auth state in the DB.
#           Generate with: openssl rand -hex 32
#           WARNING: changing this invalidates all stored sessions.
SESSION_ENCRYPTION_KEY=

# ── Queue / Delay engine ─────────────────────────────────────────────────────

# OPTIONAL  Gaussian mean inter-message delay in milliseconds (default: 120000 = 2min).
#           Safe WhatsApp range: 60,000–480,000. Do NOT go below 60,000 on new numbers.
#           UAE recommendation: 120,000 (2 min mean — balanced throughput vs ban safety).
DELAY_MEAN_MS=120000

# OPTIONAL  Gaussian standard deviation for delay in milliseconds (default: 35000).
#           Larger values produce more natural-looking human variance.
DELAY_STD_DEV_MS=35000

# OPTIONAL  Hard minimum delay floor in milliseconds (default: 60000 = 1min).
#           Worker enforces this via Redis regardless of BullMQ queue timing.
DELAY_FLOOR_MS=60000

# OPTIONAL  Hard maximum delay ceiling in milliseconds (default: 480000 = 8min).
#           Upper cap prevents outlier Gaussian draws from stalling campaigns.
DELAY_CEILING_MS=480000

# OPTIONAL  Typing indicator duration before each Baileys send (ms, default: 3000).
#           3000ms (3s) mimics natural human typing pace for short outreach messages.
TYPING_SIMULATION_MS=3000

# OPTIONAL  Maximum messages per session per calendar day (default: 200).
DAILY_SEND_LIMIT=200

# OPTIONAL  IANA timezone for the active-hours gate.
#           Set to your target market timezone so messages only send during local business hours.
#           Examples: Asia/Dubai | Asia/Karachi | Africa/Lagos | America/New_York | Europe/London
ACTIVE_HOURS_TIMEZONE=Asia/Dubai

# OPTIONAL  How many hours before a proxy assignment is rotated (default: 48).
PROXY_ROTATION_HOURS=48

# ── Frontend ─────────────────────────────────────────────────────────────────

# REQUIRED  Internal URL the NestJS API is reachable at inside Docker (used by Next.js server-side calls).
#           In docker-compose this is the service name: http://api:3001
API_URL=http://api:3001

# REQUIRED  URL of the NestJS API as seen from the browser (used by Socket.io).
#           In production this is your domain (nginx proxies /api/* internally).
#           In local dev: http://localhost:3001
NEXT_PUBLIC_API_URL=https://yourdomain.com

# REQUIRED  Allowed CORS origin for the API (set to your frontend URL).
FRONTEND_URL=https://yourdomain.com

# ── Server ────────────────────────────────────────────────────────────────────

# OPTIONAL  Port the NestJS API listens on (default: 3001).
PORT=3001

# OPTIONAL  Filesystem path for uploaded media files (default: uploads/ next to process cwd).
#           In Docker, mount a volume here to persist uploads across container restarts.
UPLOAD_DIR=uploads

# ── AI model override ─────────────────────────────────────────────────────────

# OPTIONAL  AI model ID to use (default: claude-haiku-4-5 for Anthropic, gpt-4o for OpenAI).
#           For Anthropic: claude-haiku-4-5 | claude-sonnet-4-6 | claude-opus-4-8
#           For OpenAI: gpt-4o | gpt-4o-mini | gpt-4-turbo
AI_MODEL=
